{
  "name": "software-factory-simulator",
  "private": true,
  "version": "0.1.0",
  "description": "Full-stack software development company simulator",
  "license": "MIT",
  "author": "ngmiguel",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "pnpm run --parallel dev",
    "dev:api": "pnpm --filter @sfs/api dev",
    "dev:web": "pnpm --filter @sfs/web dev",
    "build": "pnpm run -r build",
    "lint": "pnpm run -r lint",
    "lint:fix": "pnpm run -r lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md,yml,yaml}\"",
    "test": "pnpm test:all",
    "test:all": "pnpm test:shared && pnpm test:api && pnpm test:web",
    "test:pre-push": "pnpm lint && pnpm typecheck && pnpm test:all",
    "test:shared": "pnpm --filter @sfs/shared test",
    "test:shared:roles": "pnpm --filter @sfs/shared test:roles",
    "test:api": "pnpm --filter @sfs/api test",
    "test:api:health": "pnpm --filter @sfs/api test:health",
    "test:api:auth": "pnpm --filter @sfs/api test:auth",
    "test:api:auth:register": "pnpm --filter @sfs/api test:auth:register",
    "test:api:auth:login": "pnpm --filter @sfs/api test:auth:login",
    "test:api:auth:rbac": "pnpm --filter @sfs/api test:auth:rbac",
    "test:api:modules": "pnpm --filter @sfs/api test:modules",
    "test:web": "pnpm --filter @sfs/web test",
    "test:web:lib": "pnpm --filter @sfs/web test:lib",
    "typecheck": "pnpm run -r typecheck",
    "prepare": "husky",
    "db:generate": "pnpm --filter @sfs/api db:generate",
    "db:migrate": "pnpm --filter @sfs/api db:migrate",
    "db:studio": "pnpm --filter @sfs/api db:studio"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "eslint": "^9.18.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.1",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.21.0"
  }
}
